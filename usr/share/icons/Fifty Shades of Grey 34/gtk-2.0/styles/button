style "button" 
{
  
	xthickness = 4
	ythickness = 4

  engine "pixmap"
  {
    image
    {
      function			= BOX
      detail			= "buttondefault"
      recolorable		= TRUE
      file			= "Buttons/button-default.png"
      border			= { 5, 5, 5, 5 }
      stretch			= TRUE
    }
    image
    {
      function			= BOX
      state			= PRELIGHT
      recolorable		= TRUE
      file			= "Buttons/button-prelight.png"
      border			= { 5, 5, 5, 5 }
	overlay_file            = "Buttons/border-active.png"
	overlay_border          = { 7, 7, 7, 7 }
	overlay_stretch         = TRUE
      stretch			= FALSE
    }
    image
    {
      function			= BOX
      state			= ACTIVE
      file			= "Buttons/button-pressed.png"
      border			= { 5, 5, 5, 5 }
	overlay_file            = "Buttons/border-active.png"
	overlay_border          = { 7, 7, 7, 7 }
	overlay_stretch         = TRUE
     stretch			= FALSE
    }	
    image 
   {
     function			= BOX
     state			= INSENSITIVE
     file			= "Buttons/button-insensitive.png"
      border			= { 5, 5, 5, 5 }
	overlay_file            = "Buttons/border.png"
	overlay_border          = { 7, 7, 7, 7 }
	overlay_stretch         = TRUE
     stretch			= FALSE
    }
    image 
    {
      function			= BOX
      file			= "Buttons/button-normal.png"		
      border			= { 5, 5, 5, 5 }
	overlay_file            = "Buttons/border.png"
	overlay_border          = { 7, 7, 7, 7 }
	overlay_stretch         = TRUE
     stretch			= FALSE
     }	
  }
}

class "GtkButton"	style "button"
widget_class "*GtkToggleButton*"   style "button"
