<?xml version="1.0"?>
<metacity_theme>

	<constant name="TitleHeight" value="33"/>
	<constant name="TitleWidth" value="26"/>
	<constant name="BottomHeight" value="18"/>
	<constant name="BottomWidth" value="18"/>
	<constant name="ButtonYOffset" value="0"/>

	<info>
  <name>Fifty Shades of Grey 52</name>
  <author>ZMA zma.05@mail.ru</author>
  <copyright>GNU GPL</copyright>
  <date>12.06.2013</date>
  <description>Пятьдесят оттенков серого 52</description>
	</info>

	<frame_geometry name="normal" title_scale="medium" rounded_bottom_left="true" rounded_bottom_right="true" rounded_top_left="true" rounded_top_right="true">
  <distance name="left_width" value="10"/>
  <distance name="right_width" value="10"/>
  <distance name="bottom_height" value="18"/>
  <distance name="left_titlebar_edge" value="19"/>
  <distance name="right_titlebar_edge" value="19"/>
  <distance name="button_width" value="28"/>
  <distance name="button_height" value="31"/>
		<distance name="title_vertical_pad" value="0"/>
		<border name="title_border" left="4" right="4" top="0" bottom="0"/>
		<border name="button_border" left="0" right="0" top="3" bottom="0"/>
	</frame_geometry>

<frame_geometry name="borderless" rounded_top_left="true" rounded_top_right="true" parent="normal">
  <distance name="right_width" value="0"/>
  <distance name="left_width" value="0"/>
  <distance name="bottom_height" value="0"/>
</frame_geometry>


<!--title active-->
	<draw_ops name="title_tile_active"> 
		<image filename="title-active.png" alpha="1.0" x="0" y="0" width="object_width" height="object_height"/>
	</draw_ops>

	<draw_ops name="draw_titlebar">
		<tile name="title_tile_active" tile_width="TitleWidth" tile_height="TitleHeight"/>
<line color="#000000" x1="0" y1="0" x2="width" y2="0" width="0"/>
		<image filename="top-left-active.png" x="0" y="height - object_height" width="object_width" height="object_height"/>
		<image filename="top-right-active.png" x="width - object_width" y="height - object_height" width="object_width" height="object_height"/>
	</draw_ops>

	<draw_ops name="draw_title">
		<title color="#000000" x="0" y="(height - title_height) / 2"/>
	</draw_ops>

<!--title inactive-->
	<draw_ops name="title_tile_inactive">
		<image filename="title-inactive.png" alpha="1.0" x="0" y="0" width="object_width" height="object_height"/>
	</draw_ops>

	<draw_ops name="draw_titlebar_inactive">
		<tile name="title_tile_inactive" tile_width="TitleWidth" tile_height="TitleHeight"/>
<line color="#000000" x1="0" y1="0" x2="width" y2="0" width="0"/>
		<image filename="top-left-inactive.png" x="0" y="height - object_height" width="object_width" height="object_height"/>
		<image filename="top-right-inactive.png" x="width - object_width" y="height - object_height" width="object_width" height="object_height"/>
	</draw_ops>

	<draw_ops name="draw_title_inactive">
		<title color="#000000" x="0" y="(height - title_height) / 2"/>
	</draw_ops>

<!--bottom active-->
	<draw_ops name="bottom_tile_active">
		<image filename="bottom-active.png" alpha="1.0" x="0" y="0" width="object_width" height="object_height"/>
	</draw_ops>

	<draw_ops name="draw_bottom_edge">
		<tile name="bottom_tile_active" tile_width="BottomWidth" tile_height="BottomHeight"/>
<line color="#000000" x1="0" y1="height-1" x2="width" y2="height-1" width="0"/>
		<image filename="bottom-left-active.png" x="0" y="height - object_height" width="object_width" height="object_height"/>
		<image filename="bottom-right-active.png" x="width - object_width" y="height - object_height" width="object_width" height="object_height"/>
	</draw_ops>

<!--bottom inactive-->
	<draw_ops name="bottom_tile_inactive">
		<image filename="bottom-inactive.png" alpha="1.0" x="0" y="0" width="object_width" height="object_height"/>
	</draw_ops>

	<draw_ops name="draw_bottom_edge_inactive">
		<tile name="bottom_tile_inactive" tile_width="BottomWidth" tile_height="BottomHeight"/>
<line color="#000000" x1="0" y1="height-1" x2="width" y2="height-1" width="0"/>
		<image filename="bottom-left-inactive.png" x="0" y="height - object_height" width="object_width" height="object_height"/>
		<image filename="bottom-right-inactive.png" x="width - object_width" y="height - object_height" width="object_width" height="object_height"/>
	</draw_ops>


<!--left edge active-->
	<draw_ops name="draw_left_edge">
			<image filename="left-active.png" alpha="1.0" x="0" y="0" width="object_width" height="object_height"/> 

<line color="#000000" x1="0" y1="0" x2="0" y2="height-1" width="0"/>

	</draw_ops>

<!--left edge inactive-->
	<draw_ops name="draw_left_edge_inactive">
			<image filename="left-inactive.png" alpha="1.0" x="0" y="0" width="object_width" height="object_height"/>

<line color="#000000" x1="0" y1="0" x2="0" y2="height-1" width="0"/>
 
	</draw_ops>

<!--right edge active-->
	<draw_ops name="draw_right_edge">
			<image filename="right-active.png" alpha="1.0" x="0" y="0" width="object_width" height="object_height"/> 

<line color="#000000" x1="width-1" y1="0" x2="width-1" y2="height-1" width="0"/>

	</draw_ops>

<!--right edge inactive-->
	<draw_ops name="draw_right_edge_inactive">


			<image filename="right-inactive.png" alpha="1.0" x="0" y="0" width="object_width" height="object_height"/>

<line color="#000000" x1="width-1" y1="0" x2="width-1" y2="height-1" width="0"/>
 
	</draw_ops>

<!-- Active (focused) style -->
	<frame_style name="focused" geometry="normal">

		<piece position="title">
			<draw_ops>
				<include name="draw_title"/>
			</draw_ops>
		</piece>

		<piece position="titlebar">
			<draw_ops>
				<include name="draw_titlebar"/>
			</draw_ops>
		</piece>

		<piece position="left_edge">
			<draw_ops>
				<include name="draw_left_edge"/>
			</draw_ops>
		</piece>

		<piece position="right_edge">
			<draw_ops>
				<include name="draw_right_edge"/>
			</draw_ops>
		</piece>

		<piece position="bottom_edge">
			<draw_ops>
				<include name="draw_bottom_edge"/>
			</draw_ops>
		</piece>

		<button function="close" state="normal">
			<draw_ops>
				<image filename="close-active.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="close" state="pressed">
			<draw_ops>
				<image filename="close-pressed.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="close" state="prelight">
			<draw_ops>
				<image filename="close-prelight.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="minimize" state="normal">
			<draw_ops>
				<image filename="hide-active.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="minimize" state="pressed">
			<draw_ops>
				<image filename="hide-pressed.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="minimize" state="prelight">
			<draw_ops>
				<image filename="hide-prelight.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="maximize" state="normal">
			<draw_ops>
				<image filename="maximize-active.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="maximize" state="pressed">
			<draw_ops>
				<image filename="maximize-pressed.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="maximize" state="prelight">
			<draw_ops>
				<image filename="maximize-prelight.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="menu" state="normal">
			<draw_ops>
				<image filename="menu-active.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="menu" state="pressed">
			<draw_ops>
				<image filename="menu-pressed.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="menu" state="prelight">
			<draw_ops>
				<image filename="menu-prelight.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

	</frame_style>

<!-- Inactive style -->
	<frame_style name="normal" geometry="normal">

		<piece position="title">
			<draw_ops>
				<include name="draw_title_inactive"/>
			</draw_ops>
		</piece>

		<piece position="titlebar">
			<draw_ops>
				<include name="draw_titlebar_inactive"/>
			</draw_ops>
		</piece>

		<piece position="left_edge">
			<draw_ops>
				<include name="draw_left_edge_inactive"/>
			</draw_ops>
		</piece>

		<piece position="right_edge">
			<draw_ops>
				<include name="draw_right_edge_inactive"/>
			</draw_ops>
		</piece>

		<piece position="bottom_edge">
			<draw_ops>
				<include name="draw_bottom_edge_inactive"/>
			</draw_ops>
		</piece>

		<button function="close" state="normal">
			<draw_ops>
				<image filename="close-inactive.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="close" state="pressed">
			<draw_ops>
				<image filename="close-inactive.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="minimize" state="normal">
			<draw_ops>
				<image filename="hide-inactive.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="minimize" state="pressed">
			<draw_ops>
				<image filename="hide-inactive.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="maximize" state="normal">
			<draw_ops>
				<image filename="maximize-inactive.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="maximize" state="pressed">
			<draw_ops>
				<image filename="maximize-inactive.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="menu" state="normal">
			<draw_ops>
				<image filename="menu-inactive.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

		<button function="menu" state="pressed">
			<draw_ops>
				<image filename="menu-inactive.png" x="0" y="ButtonYOffset" width="object_width" height="object_height"/>
			</draw_ops>
		</button>

	</frame_style>

<!-- Active (focused) shaded style -->
	<frame_style name="normal_shaded" geometry="normal" parent="normal">
	</frame_style>
<!-- Active (focused) shaded style -->
	<frame_style name="focused_shaded" geometry="normal" parent="focused">
	</frame_style>

	<frame_style_set name="normal">
		<frame focus="yes" state="shaded" style="focused_shaded"/>
		<frame focus="yes" state="normal" resize="both" style="focused"/>
		<frame focus="yes" state="maximized" style="focused"/>
		<frame focus="yes" state="maximized_and_shaded" style="focused_shaded"/>
		<frame focus="no" state="normal" resize="both" style="normal"/>
		<frame focus="no" state="shaded" style="normal_shaded"/>
		<frame focus="no" state="maximized" style="normal"/>
		<frame focus="no" state="maximized_and_shaded" style="normal_shaded"/>
	</frame_style_set>

	<window type="normal" style_set="normal"/>
	<window type="dialog" style_set="normal"/>
	<window type="modal_dialog" style_set="normal"/>
	<window type="menu" style_set="normal"/>
	<window type="utility" style_set="normal"/>
	<window type="border" style_set="normal"/>

</metacity_theme>
